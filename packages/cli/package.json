{
  "name": "repowiki-agent",
  "version": "0.6.0",
  "description": "RepoWiki 命令行工具",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-time-forever/repowikiagent.git",
