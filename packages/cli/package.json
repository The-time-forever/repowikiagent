{
  "name": "repowiki-agent",
  "version": "0.1.0",
  "description": "RepoWiki 命令行工具",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "repowiki": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "repowiki-core": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "rimraf": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
